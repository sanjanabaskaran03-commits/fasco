<header>
    <nav style="background: #004d40; display:flex; align-items: center; justify-content: space-between; padding: 20px;">
        <div style="display: flex; align-items: center; gap: 20px;">
            <a href="/" style="color:#fff; text-decoration:none;">Shop</a>
            <a href="/products" style="color:#fff; text-decoration:none;">Products</a>

            <% if (isAuthenticated) { %>
                <a href="/cart" style="color:#fff; text-decoration:none;">Cart</a>
                <a href="/orders" style="color:#fff; text-decoration:none;">Orders</a>
                <a href="/admin/add-product" style="color:#fff; text-decoration:none;">Add Product</a>
                <a href="/admin/products" style="color:#fff; text-decoration:none;">Admin Products</a>
            <% } %>
        </div>

        <div style="display: flex; align-items: center; gap: 20px;">
            <% if (!isAuthenticated) { %>
                <a href="/login" style="color:#fff; text-decoration:none;">Login</a>
                <a href="/signup" style="color:#fff; text-decoration:none;">Signup</a>
            <% } else { %>
                <form action="/logout" method="POST" style="margin: 0;">
                    <button type="submit" style="background: none; border: none; color: #fff; cursor: pointer; font-family: inherit; font-size: inherit;">
                        Logout
                    </button>
                </form>
            <% } %>
        </div>
    </nav>
</header>