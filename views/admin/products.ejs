<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= pageTitle %></title>
    
    <style>
        :root {
            --primary: #1e293b;
            --accent-blue: #2563eb;
            --danger-red: #ef4444;
            --bg-gray: #f8fafc;
            --text-dark: #0f172a;
            --text-muted: #64748b;
            --border: #e2e8f0;
        }

        body {
            font-family: 'Inter', system-ui, -apple-system, sans-serif;
            background-color: var(--bg-gray);
            margin: 0;
            color: var(--text-dark);
        }

        .container {
            max-width: 1100px;
            margin: 40px auto;
            padding: 0 20px;
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid var(--border);
            flex-wrap: wrap;
            gap: 20px;
        }

        .admin-header h1 {
            margin: 0;
            font-size: 1.75rem;
            font-weight: 800;
            letter-spacing: -0.025em;
        }

        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
            gap: 20px;
        }

        .card {
            background: white;
            border-radius: 12px;
            border: 1px solid var(--border);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
            transition: transform 0.2s, box-shadow 0.2s;
            overflow: hidden;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
        }

        .card__content {
            padding: 24px;
        }

        .card__content h2 {
            margin: 0 0 15px 0;
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--text-dark);
        }

        .card__actions {
            display: flex;
            gap: 10px;
            margin-top: 10px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 10px 20px;
            text-decoration: none;
            border-radius: 8px;
            font-size: 0.9rem;
            font-weight: 600;
            cursor: pointer;
            border: none;
            transition: all 0.2s;
            white-space: nowrap;
        }

        .btn-primary { 
            background: var(--accent-blue); 
            color: white; 
            flex: 1;
        }
        
        .btn-danger { 
            background: #fff; 
            color: var(--danger-red);
            border: 1.5px solid var(--danger-red);
            flex: 1;
        }

        .btn-add {
            background: var(--primary);
            color: white;
            width: auto;
        }
        .btn:hover {
            opacity: 0.9;
            filter: brightness(1.1);
        }

        .btn-danger:hover {
            background: var(--danger-red);
            color: white;
        }

        .no-prods {
            grid-column: 1 / -1;
            text-align: center;
            padding: 60px;
            background: #fff;
            border-radius: 12px;
            color: var(--text-muted);
            border: 2px dashed var(--border);
        }
        header{
            border-bottom: 2px solid var(--border);
            height: 70px;
        }
    </style>
</head>
<body>
      <%- include('../includes/navigation.ejs') %>  

    <main class="container">
        <div class="admin-header">
            <h1>Product Management</h1>
            <a href="/admin/add-product" class="btn btn-add">Add New Product</a>
        </div>
        
        <div class="product-grid">
            <% if (prods.length > 0) { %>
                <% for (let product of prods) { %>
                    <article class="card">
                        <div class="card__content">
                            <h2><%= product.title %></h2>
                            <div class="card__actions">
                                <a href="/admin/edit-product/<%= product._id %>?edit=true" class="btn btn-primary">Edit</a>
                                
                                <form action="/admin/delete-product" method="POST" style="flex: 1; display: flex;">
                                    <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                    <input type="hidden" name="productId" value="<%= product._id %>">
                                    <button class="btn btn-danger" type="submit" style="width: 100%;">Delete</button>
                                </form>
                            </div>
                        </div>
                    </article>
                <% } %>
            <% } else { %>
                <div class="no-prods">
                    <h3>No products in your inventory.</h3>
                    <p>Start by clicking the "Add New Product" button above.</p>
                </div>
            <% } %>
        </div>
    </main>

</body>
</html>
